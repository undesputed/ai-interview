# ────────────────────────────────────────────────────────────────────────
# Shared env for the monorepo. Copy to .env.local in each app as needed.
# docker-compose.yml sets its own service envs — these are for native dev.
# ────────────────────────────────────────────────────────────────────────

# Web (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000

# API (apps/api)
PORT=8787
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000

# Auth — REQUIRED. Generate a real one in prod with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-only-secret-please-replace-in-production-do-not-ship-this-value

# Postgres
# Native dev (running pnpm dev on host, with `docker compose up -d postgres`):
#   host = localhost
# In docker compose (api running inside the container):
#   host = postgres  (overridden in docker-compose.yml)
DATABASE_URL=postgresql://molave:molave_local@localhost:5432/molave?schema=public
POSTGRES_USER=molave
POSTGRES_PASSWORD=molave_local
POSTGRES_DB=molave
